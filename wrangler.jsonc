{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "svyne-frontend",
  "compatibility_date": "2026-05-24",
  "observability": {
    "enabled": true
  },
  "assets": {
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "env": {
    "preview": {
      "name": "preview-svyne-frontend"
    }
  }
}
